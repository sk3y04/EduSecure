@startuml
skinparam classAttributeIconSize 0

class AuthController
class ApiExceptionHandler
class SystemController
class SubmissionController
class GradeController

class AuthService
class MfaService
class SubmissionService
class GradeService
class AuditService
class AuthApiException {
  +status: HttpStatus
  +message: String
}

interface ICryptoService {
  +encryptFile(bytes, key)
  +decryptFile(bytes, key)
  +hash(bytes)
  +sign(bytes, privateKey)
  +verify(bytes, signature, publicKey)
  +computeAuditMac(data, secret)
}

class AesRsaCryptoService {
  +encryptFile(bytes, key)
  +decryptFile(bytes, key)
  +hash(bytes)
  +sign(bytes, privateKey)
  +verify(bytes, signature, publicKey)
  +computeAuditMac(data, secret)
}

class JwtService
class JwtAuthenticationFilter
class CustomUserDetailsService
class SecurityConfig
class PasswordEncoder

class ValidationErrorResponse {
  +message: String
  +errors: Map<String, List<String>>
}

class User {
  +id: UUID
  +email: String
  +passwordHash: String
  +fullName: String
  +roles: Set<Role>
  +mfaEnabled: boolean
  +mfaMethod: MfaMethod
  +mfaSecretCiphertext: String
  +mfaSecretNonce: String
  +mfaSecretKeyVersion: String
  +mfaEnabledAt: Instant
}

class Role {
  +name: RoleName
}

enum RoleName {
  STUDENT
  LECTURER
  ADMIN
}

enum MfaMethod {
  TOTP
}

class MfaChallenge {
  +id: UUID
  +mfaMethod: MfaMethod
  +expiresAt: DateTime
  +consumedAt: DateTime
  +attemptCount: int
  +maxAttempts: int
  +createdAt: DateTime
}

class MfaRecoveryCode {
  +id: UUID
  +codeHash: String
  +usedAt: DateTime
  +createdAt: DateTime
}

class Space {
  +id: UUID
  +name: String
  +code: String
  +createdByUserId: UUID
}

class SpaceMembership {
  +id: UUID
  +spaceId: UUID
  +studentUserId: UUID
  +addedByUserId: UUID
}

class Assignment {
  +id: UUID
  +title: String
  +dueAt: DateTime
  +createdByLecturerId: UUID
  +spaceId: UUID
  +open: boolean
}

class Submission {
  +id: UUID
  +filePath: String
  +hashDigest: String
  +digitalSignature: String
  +submittedAt: DateTime
}

class Grade {
  +id: UUID
  +value: String
  +updatedAt: DateTime
}

class AuditLog {
  +id: UUID
  +actionType: String
  +actorId: UUID
  +entityType: String
  +entityId: UUID
  +integrityMac: String
  +createdAt: DateTime
}

AuthController --> AuthService
AuthController ..> ApiExceptionHandler
SubmissionController --> SubmissionService
GradeController --> GradeService

ApiExceptionHandler --> ValidationErrorResponse
ApiExceptionHandler --> AuthApiException
AuthService --> MfaService
AuthService ..> AuthApiException
MfaService ..> AuthApiException
SubmissionService --> ICryptoService
GradeService --> AuditService
AuditService --> ICryptoService
AuthService --> JwtService
AuthService --> PasswordEncoder
SecurityConfig --> JwtAuthenticationFilter
SecurityConfig --> CustomUserDetailsService
CustomUserDetailsService --> User
JwtAuthenticationFilter --> JwtService
JwtAuthenticationFilter --> CustomUserDetailsService

AesRsaCryptoService ..|> ICryptoService

User "*" -- "*" Role
User --> MfaMethod
User "1" -- "0..*" MfaChallenge
User "1" -- "0..*" MfaRecoveryCode
Role --> RoleName
Space "1" -- "*" Assignment
Space "1" -- "*" SpaceMembership
User "1" -- "*" SpaceMembership
User "1" -- "*" Submission
Assignment "1" -- "*" Submission
Submission "0..1" -- "1" Grade
GradeService --> Grade
SubmissionService --> Submission
AuditService --> AuditLog

note bottom of User
  MFA attributes are now implemented
  in the backend authentication model.
end note

note right of MfaService
  Implemented service responsibility:
  - TOTP enrollment
  - MFA challenge lifecycle
  - recovery-code handling
  - second-factor verification before JWT issuance
end note

note right of ApiExceptionHandler
  Centralises auth API failures into one envelope:
  - field-level validation errors
  - malformed request-body errors
  - auth/business errors via _global entries
end note

note right of AuthApiException
  Used for non-validation auth-domain outcomes
  while preserving HTTP status codes such as
  401, 404, 409, 410, and 429.
end note

note right of Assignment
Current implementation links assignments to spaces.
Students see assignments only through current space
memberships, while lecturers remain owner-scoped and
admins retain global oversight.
end note
@enduml

