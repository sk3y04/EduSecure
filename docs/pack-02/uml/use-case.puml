@startuml
left to right direction
skinparam packageStyle rectangle

actor Student
actor Lecturer
actor Admin

rectangle EduSecure {
  usecase "Authenticate" as UC1
  usecase "Access Course Materials" as UC2
  usecase "Submit Assignment" as UC3
  usecase "Verify Assignment Authorship" as UC4
  usecase "View Own Grades" as UC5
  usecase "Record / Update Grades" as UC6
  usecase "Review Audit Trail" as UC7
  usecase "Manage Users and Roles" as UC8
  usecase "Manage Courses" as UC9
}

Student --> UC1
Student --> UC2
Student --> UC3
Student --> UC5

Lecturer --> UC1
Lecturer --> UC2
Lecturer --> UC4
Lecturer --> UC6

Admin --> UC1
Admin --> UC7
Admin --> UC8
Admin --> UC9

Admin --> UC6 : oversight / exception review
UC6 ..> UC7 : <<logs>>
UC3 ..> UC4 : <<integrity check>>
@enduml

