# EduSecure production environment example
# Copy to /srv/edusecure/.env.prod and replace every placeholder before deployment.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=edusecure
POSTGRES_USER=edusecure_app
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_PASSWORD

# -----------------------------------------------------------------------------
# Browser / cookie / CORS posture
# Same-origin deployment via https://edusecure.skey.ovh and /api
# -----------------------------------------------------------------------------
APP_CORS_ALLOWED_ORIGINS=https://edusecure.skey.ovh
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Core application secrets
# Replace these with strong random values. Do not reuse dev defaults.
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_BASE64_SECRET
MFA_SECRET_ENCRYPTION_KEY=REPLACE_WITH_BASE64_SECRET
MFA_SECRET_KEY_VERSION=v1
MFA_ISSUER=EduSecure
AUDIT_HMAC_SECRET=REPLACE_WITH_BASE64_SECRET
SUBMISSION_STORAGE_MASTER_KEY=REPLACE_WITH_BASE64_SECRET
SUBMISSION_STORAGE_MASTER_KEY_VERSION=v1

# -----------------------------------------------------------------------------
# Upload / content limits
# Keep backend limits aligned with reverse-proxy limits.
# -----------------------------------------------------------------------------
SUBMISSION_UPLOAD_MAX_FILE_SIZE=5MB
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=5MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=6MB

# -----------------------------------------------------------------------------
# Optional shared-space chat
# Leave APP_CHAT_ENABLED=false unless you also start the Compose stack with
# the `chat` profile so MongoDB is available.
# -----------------------------------------------------------------------------
APP_CHAT_ENABLED=false
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/edusecure
SPRING_DATA_MONGODB_DATABASE=edusecure

